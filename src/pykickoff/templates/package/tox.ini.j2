[tox]
minversion = 3.10.0
envlist = python3.9, python3.10, python3.11, python3.12, python3.13, python3.14, ruff, mypy
isolated_build = True

[gh-actions]
python =
	3.9: python3.9, ruff, mypy
    3.10: python3.10
    3.11: python3.11
    3.12: python3.12
    3.13: python3.13
    3.14: python3.14

[testenv]
deps =
    pytest
commands = pytest

[testenv:mypy]
basepython = python3.10
; deps = -r {toxinidir}/requirements_dev.txt		# Don't need if can use relative path
deps = -r requirements_dev.txt
commands = mypy src/

[testenv:ruff]
basepython = python3.10
deps = ruff
commands =
    ruff check src/ tests
    ruff format src/ tests