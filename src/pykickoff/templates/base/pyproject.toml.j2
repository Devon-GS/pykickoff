[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">=3.8"
authors = [
  {name = "{{ author_name }}"}
maintainers = [
  {}
]
license = {file = "LICENSE.txt"}
keywords = [
]
classifiers = [
]
dependencies = [
    # Add your dependencies here
]

{% if is_cli %}
[project.scripts]
{{ project_name }} = "{{ project_name }}.__main__:main"
{% endif %}